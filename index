<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Just Friends Flowers</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --brown: #76604a;
    --cream: #f5f0ea;
    --white: #ffffff;
    --header-h: 70px;
    --side-margin: 48px;
  }

  html { scroll-behavior: smooth; }
  body { font-family: 'Jost', sans-serif; background: var(--brown); overflow-x: hidden; }

  /* ── HEADER ── */
  #site-header {
    position: fixed; top: 0; left: 0; right: 0;
    height: var(--header-h);
    background: rgba(255,255,255,0.70);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex; align-items: center; justify-content: center;
    z-index: 100;
    transition: transform 0.45s cubic-bezier(0.4,0,0.2,1), opacity 0.45s ease;
  }
  #site-header.hidden {
    transform: translateY(-100%);
    opacity: 0;
  }
  .logo-svg {
    height: 38px; width: auto;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    width: 100%; height: 100vh;
    overflow: hidden;
  }
  .hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: opacity 0.05s linear;
  }
  .hero-img.gray   { z-index: 2; }
  .hero-img.color  { z-index: 1; }

  /* ── CONTENT AREA ── */
  .content-area {
    background: var(--brown);
    position: relative; z-index: 5;
  }

  /* ── OUR FRIENDS ── */
  .friends-section {
    padding: 80px var(--side-margin);
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }
  .friends-text {
    flex: 1;
    color: var(--cream);
  }
  .friends-text h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.8rem, 5vw, 5rem);
    letter-spacing: 0.04em;
    margin-bottom: 28px;
    line-height: 1.05;
  }
  .friends-text p {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.85;
    color: rgba(245,240,234,0.85);
    max-width: 480px;
    letter-spacing: 0.01em;
  }
  .friends-img-wrap {
    flex: 0 0 420px;
    max-width: 420px;
  }
  .friends-img-wrap img {
    width: 100%; border-radius: 2px;
    display: block;
  }

  /* ── GALLERY ── */
  .gallery-section {
    padding: 60px 0 80px;
  }
  .gallery-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(245,240,234,0.55);
    padding: 0 var(--side-margin);
    margin-bottom: 24px;
  }
  .gallery-track-wrap {
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0 var(--side-margin);
  }
  .gallery-track-wrap::-webkit-scrollbar { display: none; }
  .gallery-track {
    display: flex;
    gap: 12px;
    width: max-content;
  }
  .gallery-slot {
    flex: 0 0 calc(55vw - var(--side-margin));
    aspect-ratio: 1 / 1;
    background: rgba(255,255,255,0.08);
    border-radius: 2px;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    position: relative;
  }
  .gallery-slot img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }
  .gallery-slot .gallery-placeholder {
    color: rgba(245,240,234,0.25);
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-style: italic;
  }

  /* ── CONTACT ── */
  .contact-section {
    padding: 80px var(--side-margin) 100px;
    border-top: 1px solid rgba(245,240,234,0.15);
  }
  .contact-section h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.2rem, 4vw, 4rem);
    color: var(--cream);
    letter-spacing: 0.04em;
    margin-bottom: 48px;
  }
  .contact-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 40px;
    max-width: 640px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-group label {
    font-size: 0.65rem;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,240,234,0.55);
  }
  .form-group input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(245,240,234,0.30);
    color: var(--cream);
    font-family: 'Jost', sans-serif;
    font-size: 0.95rem;
    font-weight: 300;
    padding: 10px 0;
    outline: none;
    transition: border-color 0.3s;
    width: 100%;
  }
  .form-group input::placeholder { color: rgba(245,240,234,0.3); }
  .form-group input:focus { border-color: rgba(245,240,234,0.7); }
  .contact-submit {
    grid-column: 1 / -1;
    margin-top: 16px;
    background: transparent;
    border: 1px solid rgba(245,240,234,0.5);
    color: var(--cream);
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 14px 40px;
    cursor: pointer;
    transition: background 0.3s, color 0.3s;
    width: fit-content;
  }
  .contact-submit:hover {
    background: var(--cream);
    color: var(--brown);
  }

  /* ── FOOTER ── */
  footer {
    background: var(--brown);
    border-top: 1px solid rgba(245,240,234,0.12);
    padding: 48px var(--side-margin);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  footer .logo-svg { filter: brightness(0) invert(1); opacity: 0.7; height: 32px; }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    :root { --side-margin: 24px; --header-h: 56px; }

    .friends-section {
      flex-direction: column;
      padding: 60px var(--side-margin);
      gap: 36px;
    }
    .friends-img-wrap {
      flex: none; max-width: 100%;
      width: 100%;
      order: -1;
    }
    .friends-text h2 { font-size: 2.6rem; }
    .gallery-slot {
      flex: 0 0 calc(80vw - var(--side-margin));
    }
    .contact-form {
      grid-template-columns: 1fr;
    }
    .contact-submit { width: 100%; text-align: center; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header id="site-header">
  <svg class="logo-svg" viewBox="0 0 440 80" xmlns="http://www.w3.org/2000/svg" aria-label="Just Friends Flowers">
    <text x="220" y="34" text-anchor="middle"
          font-family="'Jost', sans-serif" font-weight="200"
          font-size="28" letter-spacing="14" fill="#1a1a1a">JUST FRIENDS</text>
    <line x1="80" y1="52" x2="155" y2="52" stroke="#1a1a1a" stroke-width="0.8" opacity="0.6"/>
    <text x="220" y="65" text-anchor="middle"
          font-family="'Jost', sans-serif" font-weight="300"
          font-size="13" letter-spacing="10" fill="#1a1a1a">FLOWERS</text>
    <line x1="285" y1="52" x2="360" y2="52" stroke="#1a1a1a" stroke-width="0.8" opacity="0.6"/>
  </svg>
</header>

<!-- HERO -->
<section class="hero" id="hero">
  <!-- Desktop images (hidden on mobile via CSS) -->
  <img class="hero-img gray desktop-only" id="heroGray"
       src="data:image/jpeg;base64," alt=""/>
  <img class="hero-img color desktop-only" id="heroColor"
       src="data:image/jpeg;base64," alt=""/>
  <!-- Mobile images -->
  <img class="hero-img gray mobile-only" id="heroGrayMob"
       src="data:image/jpeg;base64," alt=""/>
  <img class="hero-img color mobile-only" id="heroColorMob"
       src="data:image/jpeg;base64," alt=""/>
</section>

<!-- CONTENT -->
<div class="content-area">

  <!-- OUR FRIENDS -->
  <section class="friends-section" id="friends">
    <div class="friends-text">
      <h2 id="friends-heading">Our Friends</h2>
      <p id="friends-body">We grow alongside the people who tend the earth with us — farmers, makers, and neighbours whose hands shape the seasons. Every stem we carry arrives with a name and a story attached. These are the growers we trust, the fields we return to, and the friendships that make this work feel like something more than a trade.</p>
    </div>
    <div class="friends-img-wrap">
      <img src="data:image/jpeg;base64," alt="Our Friends"/>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="gallery-section">
    <div class="gallery-label">Gallery</div>
    <div class="gallery-track-wrap">
      <div class="gallery-track" id="galleryTrack">
        <div class="gallery-slot"><span class="gallery-placeholder">Image 01</span></div>
        <div class="gallery-slot"><span class="gallery-placeholder">Image 02</span></div>
        <div class="gallery-slot"><span class="gallery-placeholder">Image 03</span></div>
        <div class="gallery-slot"><span class="gallery-placeholder">Image 04</span></div>
        <div class="gallery-slot"><span class="gallery-placeholder">Image 05</span></div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact-section" id="contact">
    <h2>Say Hello</h2>
    <form class="contact-form" onsubmit="return false;">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" placeholder="Your name"/>
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="tel" name="phone" placeholder="+1 (000) 000‑0000"/>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="hello@example.com"/>
      </div>
      <div class="form-group">
        <label>City</label>
        <input type="text" name="city" placeholder="City"/>
      </div>
      <button class="contact-submit" type="submit">Send Message</button>
    </form>
  </section>

  <!-- FOOTER -->
  <footer>
    <svg class="logo-svg" viewBox="0 0 440 80" xmlns="http://www.w3.org/2000/svg" aria-label="Just Friends Flowers">
      <text x="220" y="34" text-anchor="middle"
            font-family="'Jost', sans-serif" font-weight="200"
            font-size="28" letter-spacing="14" fill="#ffffff">JUST FRIENDS</text>
      <line x1="80" y1="52" x2="155" y2="52" stroke="#ffffff" stroke-width="0.8" opacity="0.6"/>
      <text x="220" y="65" text-anchor="middle"
            font-family="'Jost', sans-serif" font-weight="300"
            font-size="13" letter-spacing="10" fill="#ffffff">FLOWERS</text>
      <line x1="285" y1="52" x2="360" y2="52" stroke="#ffffff" stroke-width="0.8" opacity="0.6"/>
    </svg>
  </footer>

</div>

<style>
  /* Mobile/Desktop image visibility */
  @media (min-width: 769px) {
    .mobile-only { display: none !important; }
  }
  @media (max-width: 768px) {
    .desktop-only { display: none !important; }
  }
</style>

<script>
// ── HEADER HIDE/SHOW ON SCROLL ──
(function() {
  const header = document.getElementById('site-header');
  let lastY = 0;
  let ticking = false;

  window.addEventListener('scroll', function() {
    if (!ticking) {
      requestAnimationFrame(function() {
        const y = window.scrollY;
        if (y > lastY && y > 80) {
          header.classList.add('hidden');
        } else {
          header.classList.remove('hidden');
        }
        lastY = y;
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
})();

// ── HERO GRAY-TO-COLOR TRANSITION ON SCROLL ──
(function() {
  const heroEl = document.getElementById('hero');
  const isMobile = () => window.innerWidth <= 768;

  function getGrayImg() {
    return isMobile()
      ? document.getElementById('heroGrayMob')
      : document.getElementById('heroGray');
  }

  let ticking = false;
  window.addEventListener('scroll', function() {
    if (!ticking) {
      requestAnimationFrame(function() {
        const heroH = heroEl.offsetHeight;
        const scrollY = window.scrollY;
        // Transition starts at scroll=0, completes when hero is fully scrolled
        // Map scroll 0..heroH to opacity 1..0 for gray image
        const progress = Math.min(scrollY / (heroH * 0.6), 1);
        const gray = getGrayImg();
        if (gray) gray.style.opacity = 1 - progress;
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
})();
</script>


<script>
// ── CMS CONTENT LOADER ──
const JFF_KEY = "jff_cms_data";
function loadCMSContent() {
  try {
    const d = JSON.parse(localStorage.getItem(JFF_KEY)) || {};
    if (d.friendsHeading) document.getElementById("friends-heading").textContent = d.friendsHeading;
    if (d.friendsBody)    document.getElementById("friends-body").textContent    = d.friendsBody;
    if (d.contactHeading) {
      const ch = document.querySelector(".contact-section h2");
      if (ch) ch.textContent = d.contactHeading;
    }
    if (d.contactName)  { const el = document.querySelector("input[name=name]");  if(el) el.placeholder = d.contactName; }
    if (d.contactPhone) { const el = document.querySelector("input[name=phone]"); if(el) el.placeholder = d.contactPhone; }
    if (d.contactEmail) { const el = document.querySelector("input[name=email]"); if(el) el.placeholder = d.contactEmail; }
    if (d.contactCity)  { const el = document.querySelector("input[name=city]");  if(el) el.placeholder = d.contactCity; }
  } catch(e) {}
}
window.loadCMSContent = loadCMSContent;
document.addEventListener("DOMContentLoaded", loadCMSContent);
window.addEventListener("storage", function(e) {
  if (e.key === JFF_KEY) loadCMSContent();
});
</script>
</body>
</html>

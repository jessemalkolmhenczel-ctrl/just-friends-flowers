<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>JFF — CMS</title>
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@200;300;400&family=Cormorant+Garamond:ital,wght@0,300;1,300&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --brown: #76604a;
    --cream: #f5f0ea;
    --dim: rgba(245,240,234,0.6);
  }
  body {
    background: var(--brown);
    font-family: 'Jost', sans-serif;
    color: var(--cream);
    min-height: 100vh;
  }

  /* LOGIN */
  #login-screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 40px 24px;
  }
  .login-logo {
    margin-bottom: 48px;
  }
  .login-box {
    width: 100%;
    max-width: 360px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .login-box h1 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 2rem;
    letter-spacing: 0.06em;
    text-align: center;
    margin-bottom: 8px;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .field label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .field input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(245,240,234,0.3);
    color: var(--cream);
    font-family: 'Jost', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    padding: 10px 0;
    outline: none;
    transition: border-color 0.3s;
  }
  .field input:focus { border-color: var(--cream); }
  .field input::placeholder { color: rgba(245,240,234,0.25); }
  .btn {
    background: transparent;
    border: 1px solid rgba(245,240,234,0.5);
    color: var(--cream);
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 14px 24px;
    cursor: pointer;
    transition: background 0.3s, color 0.3s;
    width: 100%;
  }
  .btn:hover { background: var(--cream); color: var(--brown); }
  .btn.danger { border-color: rgba(200,120,100,0.5); color: rgba(240,180,170,0.9); }
  .btn.danger:hover { background: rgba(200,120,100,0.8); color: #fff; }
  .btn.save { background: rgba(245,240,234,0.12); }
  .btn.save:hover { background: var(--cream); color: var(--brown); }
  .error-msg {
    color: rgba(240,160,150,0.9);
    font-size: 0.8rem;
    text-align: center;
    letter-spacing: 0.05em;
    min-height: 20px;
  }

  /* CMS PANEL */
  #cms-panel {
    display: none;
    min-height: 100vh;
  }
  .cms-header {
    background: rgba(255,255,255,0.08);
    padding: 20px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(245,240,234,0.12);
  }
  .cms-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
  }
  .logout-btn {
    background: none;
    border: none;
    color: var(--dim);
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.3s;
  }
  .logout-btn:hover { color: var(--cream); }

  .cms-body {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 48px 80px;
    display: flex;
    flex-direction: column;
    gap: 60px;
  }
  .cms-section {
    border-top: 1px solid rgba(245,240,234,0.15);
    padding-top: 40px;
  }
  .cms-section h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 1.8rem;
    letter-spacing: 0.05em;
    margin-bottom: 32px;
    color: var(--cream);
  }
  .field textarea {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(245,240,234,0.2);
    border-radius: 2px;
    color: var(--cream);
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.7;
    padding: 14px 16px;
    outline: none;
    width: 100%;
    resize: vertical;
    min-height: 130px;
    transition: border-color 0.3s;
  }
  .field textarea:focus { border-color: rgba(245,240,234,0.6); }
  .save-row {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 20px;
  }
  .save-row .btn { width: auto; padding: 12px 36px; }
  .save-status {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(180,220,180,0.85);
    opacity: 0;
    transition: opacity 0.5s;
  }
  .save-status.visible { opacity: 1; }

  @media (max-width: 600px) {
    .cms-header { padding: 16px 24px; }
    .cms-body { padding: 40px 24px 60px; }
  }
</style>
</head>
<body>

<!-- LOGIN SCREEN -->
<div id="login-screen">
  <div class="login-logo">
    <svg viewBox="0 0 440 80" width="280" xmlns="http://www.w3.org/2000/svg">
      <text x="220" y="34" text-anchor="middle"
            font-family="'Jost',sans-serif" font-weight="200"
            font-size="28" letter-spacing="14" fill="#f5f0ea">JUST FRIENDS</text>
      <line x1="80" y1="52" x2="155" y2="52" stroke="#f5f0ea" stroke-width="0.8" opacity="0.5"/>
      <text x="220" y="65" text-anchor="middle"
            font-family="'Jost',sans-serif" font-weight="300"
            font-size="13" letter-spacing="10" fill="#f5f0ea">FLOWERS</text>
      <line x1="285" y1="52" x2="360" y2="52" stroke="#f5f0ea" stroke-width="0.8" opacity="0.5"/>
    </svg>
  </div>
  <div class="login-box">
    <h1>Content Editor</h1>
    <div class="field">
      <label>Username</label>
      <input type="text" id="username" placeholder="camille" autocomplete="username"/>
    </div>
    <div class="field">
      <label>Password</label>
      <input type="password" id="password" placeholder="••••••••••••" autocomplete="current-password"/>
    </div>
    <p class="error-msg" id="loginError"></p>
    <button class="btn" onclick="doLogin()">Sign In</button>
  </div>
</div>

<!-- CMS PANEL -->
<div id="cms-panel">
  <div class="cms-header">
    <h2>Content Editor</h2>
    <button class="logout-btn" onclick="doLogout()">Sign Out</button>
  </div>
  <div class="cms-body">

    <!-- OUR FRIENDS SECTION -->
    <div class="cms-section">
      <h3>Our Friends</h3>
      <div class="field" style="margin-bottom:20px;">
        <label>Section Heading</label>
        <input type="text" id="friendsHeading" placeholder="Our Friends"/>
      </div>
      <div class="field">
        <label>Body Text</label>
        <textarea id="friendsBody" rows="5"></textarea>
      </div>
      <div class="save-row">
        <button class="btn save" onclick="saveFriends()">Save Changes</button>
        <span class="save-status" id="friendsSaved">Saved ✓</span>
      </div>
    </div>

    <!-- CONTACT SECTION -->
    <div class="cms-section">
      <h3>Contact Section</h3>
      <div class="field" style="margin-bottom:20px;">
        <label>Section Heading</label>
        <input type="text" id="contactHeading" placeholder="Say Hello"/>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px 40px;">
        <div class="field">
          <label>Contact Name</label>
          <input type="text" id="contactName" placeholder=""/>
        </div>
        <div class="field">
          <label>Phone Number</label>
          <input type="tel" id="contactPhone" placeholder="+1 (000) 000‑0000"/>
        </div>
        <div class="field">
          <label>Email Address</label>
          <input type="email" id="contactEmail" placeholder="hello@example.com"/>
        </div>
        <div class="field">
          <label>City</label>
          <input type="text" id="contactCity" placeholder="City"/>
        </div>
      </div>
      <div class="save-row">
        <button class="btn save" onclick="saveContact()">Save Changes</button>
        <span class="save-status" id="contactSaved">Saved ✓</span>
      </div>
    </div>

  </div>
</div>

<script>
const CREDENTIALS = { username: 'camille', password: 'Justfriends2026' };
const STORAGE_KEY = 'jff_cms_data';

function getData() {
  try {
    return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {};
  } catch { return {}; }
}
function setData(data) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
}

function doLogin() {
  const u = document.getElementById('username').value.trim();
  const p = document.getElementById('password').value;
  if (u === CREDENTIALS.username && p === CREDENTIALS.password) {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('cms-panel').style.display = 'block';
    loadCMSFields();
  } else {
    const err = document.getElementById('loginError');
    err.textContent = 'Incorrect username or password.';
    setTimeout(() => { err.textContent = ''; }, 3000);
  }
}

function doLogout() {
  document.getElementById('cms-panel').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('username').value = '';
  document.getElementById('password').value = '';
}

// Allow Enter key
document.getElementById('password').addEventListener('keydown', e => {
  if (e.key === 'Enter') doLogin();
});
document.getElementById('username').addEventListener('keydown', e => {
  if (e.key === 'Enter') doLogin();
});

function loadCMSFields() {
  const d = getData();
  document.getElementById('friendsHeading').value = d.friendsHeading || 'Our Friends';
  document.getElementById('friendsBody').value = d.friendsBody || 'We grow alongside the people who tend the earth with us — farmers, makers, and neighbours whose hands shape the seasons. Every stem we carry arrives with a name and a story attached. These are the growers we trust, the fields we return to, and the friendships that make this work feel like something more than a trade.';
  document.getElementById('contactHeading').value = d.contactHeading || 'Say Hello';
  document.getElementById('contactName').value = d.contactName || '';
  document.getElementById('contactPhone').value = d.contactPhone || '';
  document.getElementById('contactEmail').value = d.contactEmail || '';
  document.getElementById('contactCity').value = d.contactCity || '';
}

function flash(id) {
  const el = document.getElementById(id);
  el.classList.add('visible');
  setTimeout(() => el.classList.remove('visible'), 2500);
}

function saveFriends() {
  const d = getData();
  d.friendsHeading = document.getElementById('friendsHeading').value;
  d.friendsBody = document.getElementById('friendsBody').value;
  setData(d);
  // Push to main page if open in same browser
  try { window.opener && window.opener.loadCMSContent && window.opener.loadCMSContent(); } catch {}
  flash('friendsSaved');
}

function saveContact() {
  const d = getData();
  d.contactHeading = document.getElementById('contactHeading').value;
  d.contactName = document.getElementById('contactName').value;
  d.contactPhone = document.getElementById('contactPhone').value;
  d.contactEmail = document.getElementById('contactEmail').value;
  d.contactCity = document.getElementById('contactCity').value;
  setData(d);
  flash('contactSaved');
}
</script>
</body>
</html>
